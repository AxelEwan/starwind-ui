---
import { getCollection } from 'astro:content';

// 1. 获取所有视频 md 文件生成动态路径
export async function getStaticPaths() {
  const videoEntries = await getCollection('videos');
  return videoEntries.map(entry => ({
    params: { slug: entry.slug }, props: { entry },
  }));
}

// 2. 提取当前视频的数据
const { entry } = Astro.props;
const { title, pubDate, cover, category, rating, stats, platforms, location, comments } = entry.data;
const { Content } = await entry.render();

// 3. 核心逻辑：判断是否超前发布（锁定状态）
const isLocked = new Date(pubDate) > new Date();
---

<html lang="zh-CN" class="bg-black text-white">
  <head>
    <title>{title} - AxelEwan Official</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
  </head>
  <body class="bg-black min-h-screen font-sans selection:bg-white selection:text-black">
    <main class="max-w-6xl mx-auto px-4 py-12">
      
      <div class="relative w-full aspect-video bg-zinc-900 rounded-2xl overflow-hidden shadow-[0_0_40px_rgba(0,0,0,0.4)] mb-10 group transition-all duration-500 hover:shadow-[0_0_60px_rgba(255,255,255,0.05)]">
        {isLocked ? (
          <div class="absolute inset-0 flex flex-col items-center justify-center z-10">
            <div class="absolute inset-0 bg-cover bg-center blur-2xl opacity-40 scale-110" style={`background-image: url('${cover}')`}></div>
            <div class="relative z-20 flex flex-col items-center text-center">
              <svg class="w-16 h-16 text-white mb-4 drop-shadow-lg" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path></svg>
              <h2 class="text-3xl font-bold tracking-wider mb-2">即将发布</h2>
              <p class="text-zinc-400 font-mono tracking-widest">{new Date(pubDate).toLocaleString()}</p>
            </div>
          </div>
        ) : (
          // 播放器逻辑：解析官方 ID 嵌入
          <>
            {platforms?.bilibili ? (
              <iframe src={`//player.bilibili.com/player.html?bvid=${platforms.bilibili}&page=1&autoplay=0&high_quality=1`} class="w-full h-full border-0" allowfullscreen></iframe>
            ) : platforms?.youtube ? (
              <iframe src={`https://www.youtube.com/embed/${platforms.youtube}`} class="w-full h-full border-0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>
            ) : platforms?.local ? (
              <video src={platforms.local} controls class="w-full h-full object-cover"></video>
            ) : (
              <div class="w-full h-full flex items-center justify-center bg-zinc-900 text-zinc-600">媒体源未配置</div>
            )}
          </>
        )}
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">
        
        <div class="lg:col-span-2 space-y-6">
          <h1 class="text-4xl font-extrabold tracking-tight leading-tight">{title}</h1>
          <div class="flex flex-wrap items-center gap-4 text-sm text-zinc-400">
            <span class="px-4 py-1.5 bg-zinc-800/80 rounded-full font-medium text-zinc-200">{category}</span>
            <span class="font-mono">{new Date(pubDate).toLocaleDateString()}</span>
            {location && <span class="flex items-center gap-1.5"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg> {location}</span>}
          </div>
          <div class="prose prose-invert prose-zinc max-w-none pt-4 text-zinc-300">
            <Content />
          </div>
        </div>

        <div class="space-y-6">
          <div class="bg-zinc-900/40 p-6 rounded-2xl backdrop-blur-xl border border-zinc-800/50 hover:border-zinc-700/50 transition-colors">
            <div class="grid grid-cols-3 gap-4 text-center">
              {rating && (
                <div class="flex flex-col items-center justify-center">
                  <div class="text-3xl font-bold text-white mb-1">{rating}<span class="text-sm font-normal text-zinc-500">/10</span></div>
                  <div class="w-full h-1 bg-zinc-800 rounded-full mt-1 overflow-hidden">
                    <div class="h-full bg-white" style={`width: ${rating * 10}%`}></div>
                  </div>
                </div>
              )}
              {stats?.views && (
                <div class="flex flex-col items-center justify-center">
                  <div class="text-2xl font-bold text-white">{stats.views}</div>
                  <div class="text-xs text-zinc-500 mt-2 uppercase tracking-widest">播放量</div>
                </div>
              )}
              {stats?.likes && (
                <div class="flex flex-col items-center justify-center">
                  <div class="text-2xl font-bold text-white">{stats.likes}</div>
                  <div class="text-xs text-zinc-500 mt-2 uppercase tracking-widest">点赞量</div>
                </div>
              )}
            </div>
          </div>

          <div class="bg-zinc-900/40 p-6 rounded-2xl backdrop-blur-xl border border-zinc-800/50">
            <h3 class="text-xs font-semibold text-zinc-500 mb-4 uppercase tracking-widest">在其他平台观看</h3>
            <div class="flex flex-wrap gap-3">
              {platforms?.bilibili && <a href={`https://www.bilibili.com/video/${platforms.bilibili}`} target="_blank" class="px-4 py-2 bg-[#fb7299]/10 text-[#fb7299] rounded-lg text-sm font-medium hover:bg-[#fb7299]/20 transition-colors">Bilibili</a>}
              {platforms?.youtube && <a href={`https://www.youtube.com/watch?v=${platforms.youtube}`} target="_blank" class="px-4 py-2 bg-red-500/10 text-red-500 rounded-lg text-sm font-medium hover:bg-red-500/20 transition-colors">YouTube</a>}
              {platforms?.douyin && <a href={platforms.douyin} target="_blank" class="px-4 py-2 bg-zinc-800 text-white rounded-lg text-sm font-medium hover:bg-zinc-700 transition-colors">抖音</a>}
              {platforms?.xiaohongshu && <a href={platforms.xiaohongshu} target="_blank" class="px-4 py-2 bg-red-600/10 text-red-500 rounded-lg text-sm font-medium hover:bg-red-600/20 transition-colors">小红书</a>}
            </div>
          </div>
        </div>
      </div>

      {comments && comments.length > 0 && (
        <div class="mt-20 pt-10 border-t border-zinc-800/50 relative">
          <h3 class="text-2xl font-bold mb-8">精选评论</h3>
          <div class="space-y-6 pb-20">
            {comments.map((comment, index) => (
              <div class={`flex gap-5 ${index === comments.length - 1 ? 'opacity-40 blur-[2px]' : ''}`}>
                <div class="w-12 h-12 rounded-full bg-zinc-800 overflow-hidden flex-shrink-0 border border-zinc-700">
                   {comment.avatar ? <img src={comment.avatar} alt={comment.user} class="w-full h-full object-cover"/> : <div class="w-full h-full flex items-center justify-center text-zinc-500 text-sm">用户</div>}
                </div>
                <div>
                  <div class="font-medium text-zinc-200">{comment.user}</div>
                  <div class="text-zinc-400 mt-1.5 leading-relaxed">{comment.content}</div>
                </div>
              </div>
            ))}
          </div>
          <div class="absolute bottom-0 left-0 w-full h-40 bg-gradient-to-t from-black via-black/80 to-transparent flex items-end justify-center pb-6 cursor-pointer group">
            <span class="px-6 py-2.5 bg-zinc-900/80 backdrop-blur-md rounded-full text-sm font-medium border border-zinc-700/50 text-zinc-300 group-hover:text-white group-hover:border-zinc-500 transition-all shadow-xl">
              前往源平台查看更多评论
            </span>
          </div>
        </div>
      )}
    </main>
  </body>
</html>
