---
import { getCollection } from 'astro:content';
const videos = await getCollection('videos');
import CarouselDemos from "@/components/carousel-demos/CarouselDemos.astro";
import CarouselPluginDemo from "@/components/carousel-demos/CarouselPluginDemo.astro";
import {
  AccordionDemo,
  AlertDemo,
  AlertDialogDemo,
  AspectRatioDemo,
  AvatarDemo,
  BadgeDemo,
  BreadcrumbDemo,
  ButtonDemo,
  ButtonGroupDemo,
  CardDemo,
  CheckboxDemo,
  CollapsibleDemo,
  DialogDemo,
  DropdownDemo,
  DropzoneDemo,
  FormDemo,
  ImageDemo,
  InputGroupDemo,
  InputOtpDemo,
  ItemDemo,
  KbdDemo,
  NativeSelectDemo,
  PaginationDemo,
  PopoverDemo,
  ProgressDemo,
  RadioGroupDemo,
  SelectDemo,
  SeparatorDemo,
  SheetDemo,
  SkeletonDemo,
  SliderDemo,
  SpinnerDemo,
  SwitchDemo,
  TableDemo,
  TabsDemo,
  ThemeToggleDemo,
  ToastDemo,
  ToggleDemo,
  TooltipDemo,
  VideoDemo,
} from "@/components/demos";
import Layout from "@/layouts/Layout.astro";
---

<Layout
  title="Starwind UI components demo"
  description="A collection of accessible UI components built with Astro"
>
<!-- 推荐视频 -->
<h2 class="text-3xl font-bold mb-6">最新视频作品</h2>
<div class="grid grid-cols-1 md:grid-cols-3 gap-6">
  {videos.map(video => (
    <a href={`/videos/${video.id.replace('.md', '')}`} class="group">
      <img src={video.data.cover} class="rounded-2xl w-full aspect-video object-cover transition-all group-hover:scale-105" />
      <h3 class="mt-4 text-xl font-semibold">{video.data.title}</h3>
    </a>
  ))}
</div>
  <div class="container mx-auto px-4 pb-20">
    <PopoverDemo />
    <DropdownDemo />
    <CardDemo />
    <CollapsibleDemo />
    <ThemeToggleDemo />
    <BadgeDemo />
    <ButtonDemo />
    <ButtonGroupDemo />
    <InputOtpDemo />
    <InputGroupDemo />
    <DialogDemo />
    <ToastDemo />
    <VideoDemo />
    <SliderDemo />
    <ImageDemo />
    <AccordionDemo />
    <SheetDemo />
    <AspectRatioDemo />
    <SpinnerDemo />
    <SeparatorDemo />
    <ItemDemo />
    <CarouselDemos />
    <CarouselPluginDemo />
    <DropzoneDemo />
    <ProgressDemo />
    <SkeletonDemo />
    <RadioGroupDemo />
    <BreadcrumbDemo />
    <AlertDialogDemo />
    <TabsDemo />
    <FormDemo />
    <SelectDemo />
    <NativeSelectDemo />
    <PaginationDemo />
    <SwitchDemo />
    <ToggleDemo />
    <AvatarDemo />
    <CheckboxDemo />
    <TooltipDemo />
    <AlertDemo />
    <TableDemo />
    <KbdDemo />
  </div>
</Layout>
