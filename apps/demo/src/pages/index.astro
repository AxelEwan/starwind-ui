---
import { getCollection } from 'astro:content';
import Layout from '@/layouts/Layout.astro';

const allVideos = await getCollection('videos');

// 推荐视频（自动加入轮播 + 列表）
const recommendedVideos = allVideos
  .filter(v => v.data.recommend === true)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

// 手动轮播图（优先）
const manualBanners = [
  {
    id: 1,
    bgImage: 'https://cdn1.x-lab.top/axelblog/1733584787-maydaysh5525.webp',
    title: 'AxelEwan',
    tag: '正在建设',
    intro: '记录生活 · 分享故事',
    videoSlug: '',
  },
];

// 合并成轮播图数据（手动优先 + 推荐视频）
const banners = [
  ...manualBanners,
  ...recommendedVideos.map(v => ({
    id: v.id,
    bgImage: v.data.cover,
    title: v.data.title,
    tag: v.data.tags?.[0] || '推荐',
    intro: v.data.intro || '最新力作',
    videoSlug: v.id.replace('.md', ''),
  }))
].slice(0, 8);   // 最多显示 8 个
---

<Layout title="AxelEwan | 个人作品官网" description="AxelEwan 的视频作品与最新动态">
  <main class="min-h-screen bg-black text-white">
    
    <!-- 轮播图（取消箭头和进度条） -->
    <div id="hero-carousel" class="relative h-[70vh] md:h-[85vh] min-h-[500px] overflow-hidden">
      {banners.map((banner, index) => (
        <div 
          class={`absolute inset-0 transition-opacity duration-1000 ${index === 0 ? 'opacity-100' : 'opacity-0'}`}
          data-slide={index}
        >
          <img src={banner.bgImage} class="absolute inset-0 w-full h-full object-cover" alt={banner.title} />
          <div class="absolute bottom-0 left-0 right-0 h-1/2 bg-gradient-to-t from-black via-black/80 to-transparent z-10"></div>
          
          <div class="absolute bottom-16 left-6 md:left-16 max-w-2xl z-20">
            <h1 class="text-4xl md:text-5xl font-black tracking-[-1px] leading-none drop-shadow-2xl">{banner.title}</h1>
            
            <div class="inline-flex items-center gap-2 mt-5 mb-6">
              <span class="px-4 py-1 bg-white/10 backdrop-blur-md text-white text-sm font-medium rounded-full">{banner.tag}</span>
            </div>
            
            <p class="text-base md:text-lg text-white/80 max-w-md leading-tight mb-8">{banner.intro}</p>
            
            <a href={`/videos/${banner.videoSlug}`} 
               class="inline-flex items-center gap-3 bg-white/10 hover:bg-white/20 backdrop-blur-md text-white font-medium text-base px-7 py-3 rounded-3xl transition-all border border-white/30">
              <span class="text-2xl">▶</span>
              立即观看
            </a>
          </div>
        </div>
      ))}
    </div>

    <!-- 缩略图卡片列表（鼠标悬停切换） -->
    <div class="max-w-7xl mx-auto px-6 -mt-8 md:-mt-12 relative z-30">
      <div class="flex gap-4 overflow-x-auto pb-8 snap-x snap-mandatory scrollbar-hide">
        {banners.map((banner, index) => (
          <a href={`/videos/${banner.videoSlug}`} class="group flex-shrink-0 w-52 snap-center cursor-pointer" data-slide-index={index}>
            <div class="aspect-video bg-zinc-900 rounded-xl overflow-hidden relative shadow-2xl">
              <img src={banner.bgImage} class="w-full h-full object-cover transition-all duration-300 group-hover:scale-105" alt={banner.title} />
              <div class="absolute top-3 left-3 bg-black/70 text-white text-xs font-medium px-3 py-px rounded">
                {banner.tag}
              </div>
            </div>
            <p class="text-sm font-medium mt-3 line-clamp-2 text-center group-hover:text-blue-400">{banner.title}</p>
          </a>
        ))}
      </div>
    </div>

    <!-- 最新视频作品列表 -->
    <div class="max-w-7xl mx-auto px-6 py-16">
      <div class="flex items-end justify-between mb-10">
        <h2 class="text-4xl font-bold tracking-tight">最新视频作品</h2>
        <a href="/videos" class="text-zinc-400 hover:text-white flex items-center gap-2 text-lg">全部作品 →</a>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-6">
        {recommendedVideos.map((item) => (
          <a href={`/videos/${item.id.replace('.md', '')}`} class="group relative" key={item.id}>
            <div class="aspect-video bg-zinc-900 rounded-xl overflow-hidden mb-3 relative">
              <img src={item.data.cover} class="w-full h-full object-cover transition-all duration-500 ease-out group-hover:scale-105" alt={item.data.title} />
              {item.isNew && (
                <div class="absolute top-3 left-3 bg-black/70 text-white text-xs font-medium px-3 py-px rounded">最新发布</div>
              )}
              {item.isHot && !item.isNew && (
                <div class="absolute top-3 left-3 bg-black/70 text-white text-xs font-medium px-3 py-px rounded">最热门</div>
              )}
            </div>
            <h3 class="font-semibold line-clamp-2 group-hover:text-blue-400">{item.data.title}</h3>
            <p class="text-sm text-zinc-400 mt-1">{new Date(item.data.date).toLocaleDateString('zh-CN')}</p>
          </a>
        ))}
      </div>
    </div>

    <!-- 联系方式 -->
    <div class="max-w-7xl mx-auto px-6 py-20 border-t border-zinc-800 text-center">
      <div class="flex justify-center mb-6">
        <span class="text-3xl font-black tracking-[-2px] text-white/90">AxelEwan</span>
      </div>
      <p class="text-zinc-400">商务合作 / 联系我</p>
      <a href="mailto:hi@axelewan.com" class="mt-4 inline-flex items-center gap-2 text-white hover:text-blue-400 transition-colors">
        ✉️ hi@axelewan.com
      </a>
    </div>
  </main>

  <!-- 轮播悬停切换脚本 -->
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const slides = document.querySelectorAll('#hero-carousel > div[data-slide]');
      const thumbnails = document.querySelectorAll('.flex-shrink-0[data-slide-index]');
      if (!slides.length) return;

      let current = 0;

      const showSlide = (n) => {
        slides.forEach((s, i) => s.style.opacity = i === n ? '1' : '0');
      };

      thumbnails.forEach(thumb => {
        thumb.addEventListener('mouseenter', () => {
          const idx = parseInt(thumb.dataset.slideIndex);
          current = idx;
          showSlide(current);
        });
      });
    });
  </script>
</Layout>
