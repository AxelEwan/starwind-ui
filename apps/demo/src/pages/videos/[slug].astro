---
import { getEntry } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const videos = await getCollection('videos');
  return videos.map(video => ({
    params: { slug: video.id.replace('.md', '') },
    props: { video },
  }));
}

const { video } = Astro.props;
const data = video.data;
---

<Layout title={data.title}>
  <main class="min-h-screen bg-black text-white">
    <div class="max-w-7xl mx-auto px-6 py-12">
      <!-- 视频播放器（先用占位，后面换真嵌入） -->
      <div class="aspect-video bg-zinc-900 rounded-3xl overflow-hidden mb-8 relative">
        <img src={data.cover} class="w-full h-full object-cover" alt={data.title} />
        <div class="absolute inset-0 flex items-center justify-center">
          <div class="text-4xl">▶️</div>
        </div>
      </div>

      <h1 class="text-5xl font-bold mb-4">{data.title}</h1>
      <p class="text-zinc-400">{new Date(data.date).toLocaleDateString('zh-CN')}</p>

      <p class="mt-8 text-lg">{data.intro}</p>

      <!-- 平台 LOGO 区域（后面会加上真实跳转） -->
      <div class="flex gap-4 mt-8">
        {data.platforms?.bilibili && <a href={`https://www.bilibili.com/video/${data.platforms.bilibili}`} class="text-blue-400">📺 B站</a>}
        {data.platforms?.youtube && <a href={`https://youtube.com/watch?v=${data.platforms.youtube}`} class="text-red-500">▶️ YouTube</a>}
      </div>
    </div>
  </main>
</Layout>
