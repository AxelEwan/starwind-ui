---
import { getCollection } from 'astro:content';
import Layout from '@/layouts/Layout.astro';

export async function getStaticPaths() {
  const videos = await getCollection('videos');
  return videos.map((video) => ({
    params: { slug: video.id.replace('.md', '') },
    props: { video },
  }));
}

const { video } = Astro.props;
const data = video.data;
---

<Layout title={data.title}>
  <main class="min-h-screen bg-black text-white">
    <div class="max-w-7xl mx-auto px-6 py-12">
      <!-- 视频播放器占位 -->
      <div class="aspect-video bg-zinc-900 rounded-3xl overflow-hidden mb-10 relative group">
        <img 
          src={data.cover} 
          class="w-full h-full object-cover transition-transform group-hover:scale-105" 
          alt={data.title} 
        />
        <div class="absolute inset-0 flex items-center justify-center bg-black/30">
          <div class="text-7xl text-white/80">▶️</div>
        </div>
      </div>

      <h1 class="text-5xl font-bold tracking-tight mb-3">{data.title}</h1>
      <p class="text-zinc-400 text-xl">
        {new Date(data.date).toLocaleDateString('zh-CN')}
      </p>

      <p class="mt-10 text-lg leading-relaxed text-zinc-300">{data.intro}</p>

      <!-- 平台跳转 -->
      <div class="flex flex-wrap gap-6 mt-12">
        {data.platforms?.bilibili && (
          <a href={`https://www.bilibili.com/video/${data.platforms.bilibili}`} 
             target="_blank" 
             class="flex items-center gap-3 text-blue-400 hover:text-blue-300 transition-colors">
            📺 <span class="font-medium">B站观看</span>
          </a>
        )}
        {data.platforms?.youtube && (
          <a href={`https://www.youtube.com/watch?v=${data.platforms.youtube}`} 
             target="_blank" 
             class="flex items-center gap-3 text-red-500 hover:text-red-400 transition-colors">
            ▶️ <span class="font-medium">YouTube</span>
          </a>
        )}
      </div>
    </div>
  </main>
</Layout>
