---
import { getCollection } from 'astro:content';
import Layout from '@/layouts/Layout.astro';

export async function getStaticPaths() {
  const videos = await getCollection('videos');
  return videos.map((video) => ({
    params: { slug: video.id.replace('.md', '') },
    props: { video },
  }));
}

const { video } = Astro.props;
const data = video.data;

// 判断是否是未来视频（以上海时间为准）
const now = new Date();
const publishDate = new Date(data.date);
const isFuture = publishDate > now;

// 数字格式化 K/M
function formatNumber(num: number): string {
  if (num >= 1_000_000) return (num / 1_000_000).toFixed(1) + 'M';
  if (num >= 1000) return (num / 1000).toFixed(1) + 'K';
  return num.toLocaleString();
}

const author = data.author || 'AxelEwan';
---

<Layout title={data.title}>
  <main class="min-h-screen bg-black text-white pb-20 dark:bg-zinc-950">
    <div class="max-w-7xl mx-auto px-6 pt-8">
      <!-- 视频播放器 -->
      <div class="aspect-video bg-zinc-950 rounded-3xl overflow-hidden mb-12 relative shadow-2xl">
        {isFuture ? (
          <div class="relative w-full h-full">
            <img src={data.cover} class="w-full h-full object-cover filter blur-xl" alt={data.title} />
            <div class="absolute inset-0 flex flex-col items-center justify-center bg-black/70 backdrop-blur-md">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-20 h-20 mb-6 text-white" fill="none" viewBox="0 0 256 256" stroke="currentColor" stroke-width="24" stroke-linecap="round" stroke-linejoin="round">
                <path d="M128 176a48 48 0 1 0 0-96 48 48 0 0 0 0 96Z"/>
                <path d="M128 224c-40-32-80-64-80-112a80 80 0 1 1 160 0c0 48-40 80-80 112Z"/>
              </svg>
              <div class="text-3xl font-bold mb-2">即将发布</div>
              <div id="countdown" class="text-4xl font-mono tabular-nums" data-publish-date={publishDate.getTime()}></div>
            </div>
          </div>
        ) : (
          <div class="w-full h-full">
            {data.platforms?.bilibili ? (
              <iframe src={`https://player.bilibili.com/player.html?bvid=${data.platforms.bilibili}&autoplay=0&muted=0`} class="w-full h-full" frameborder="0" allowfullscreen></iframe>
            ) : data.platforms?.youtube ? (
              <iframe src={`https://www.youtube.com/embed/${data.platforms.youtube}`} class="w-full h-full" frameborder="0" allowfullscreen></iframe>
            ) : (
              <img src={data.cover} class="w-full h-full object-cover" alt={data.title} />
            )}
          </div>
        )}
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12">
        <!-- 左侧信息 -->
        <div class="lg:col-span-8">
          <h1 class="text-5xl font-bold tracking-tighter mb-4">{data.title}</h1>
          
          <!-- 标题下方：作者名称 -->
          <div class="flex items-center gap-2 text-zinc-400 mb-8">
            <span class="text-white font-medium">{author}</span>
          </div>

          <!-- 三列：发布日期 | 播放量 | 点赞（无图标） -->
          <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-12 border-t border-b border-zinc-800 py-8">
            <div>
              <div class="text-4xl font-bold text-white">{new Date(data.date).toLocaleDateString('zh-CN')}</div>
              <div class="text-sm text-zinc-400">发布日期</div>
            </div>
            <div>
              <div class="text-4xl font-bold text-white">{formatNumber(data.views)}</div>
              <div class="text-sm text-zinc-400">播放量</div>
            </div>
            <div>
              <div class="text-4xl font-bold text-white">{formatNumber(data.likes)}</div>
              <div class="text-sm text-zinc-400">点赞</div>
            </div>
          </div>

          <p class="text-xl text-zinc-300 leading-relaxed mb-8">{data.intro}</p>

          <!-- Tag + 位置 -->
          <div class="flex flex-wrap gap-3 mb-10">
            {data.tags.map((tag: string) => (
              <span class="inline-flex items-center gap-1.5 px-4 py-1.5 bg-zinc-900 text-sm rounded-3xl">
                {tag}
              </span>
            ))}
            {data.location && (
              <span class="inline-flex items-center gap-1.5 px-4 py-1.5 text-zinc-400 text-sm">
                📍 {data.location}
              </span>
            )}
          </div>

          <!-- 评论区（保持不变） -->
          {data.enableComments && data.comments?.length > 0 && (
            <div>
              <h3 class="flex items-center gap-2 text-2xl font-semibold mb-6">观众评论</h3>
              <div class="space-y-8">
                {data.comments.map((comment: any, i: number) => (
                  <div class={`flex gap-4 ${i === data.comments.length - 1 ? 'opacity-30 blur-sm' : ''}`}>
                    <img src={comment.avatar} class="w-10 h-10 rounded-full flex-shrink-0" />
                    <div>
                      <div class="font-medium">{comment.nickname}</div>
                      <div class="text-zinc-300 mt-1">{comment.content}</div>
                    </div>
                  </div>
                ))}
              </div>
              <div class="mt-10 text-center">
                <a href={`https://www.bilibili.com/video/${data.platforms?.bilibili || ''}`} target="_blank" class="inline-flex items-center gap-2 text-blue-400 hover:text-blue-300 transition-colors">
                  查看更多评论 →
                </a>
              </div>
            </div>
          )}
        </div>

        <!-- 右侧平台 Logo -->
        <div class="lg:col-span-4">
          <div class="sticky top-8">
            <h4 class="text-lg text-zinc-400 mb-6">在其他平台观看</h4>
            <div class="flex flex-col gap-4">
              {data.platforms?.bilibili && (
                <a href={`https://www.bilibili.com/video/${data.platforms.bilibili}`} target="_blank" class="flex items-center gap-4 p-5 bg-zinc-900 hover:bg-zinc-800 rounded-2xl transition-all">
                  <!-- Bilibili (fa6-brands style) -->
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10 text-[#FB7299]" fill="currentColor" viewBox="0 0 24 24"><path d="M18.223 3.5H5.777C4.8 3.5 4 4.3 4 5.277v13.446C4 19.7 4.8 20.5 5.777 20.5h12.446c.977 0 1.777-.8 1.777-1.777V5.277C20 4.3 19.2 3.5 18.223 3.5zM8 17.25H6.5V7.75H8v9.5zm5.5 0h-1.5V7.75h1.5v9.5zm4-9.5h-1.5v9.5H17.5V7.75z"/></svg>
                  <div>
                    <div class="font-medium">Bilibili</div>
                    <div class="text-xs text-zinc-400">大陆首选</div>
                  </div>
                </a>
              )}
              {data.platforms?.youtube && (
                <a href={`https://www.youtube.com/watch?v=${data.platforms.youtube}`} target="_blank" class="flex items-center gap-4 p-5 bg-zinc-900 hover:bg-zinc-800 rounded-2xl transition-all">
                  <!-- YouTube logo-bold -->
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10 text-red-500" fill="currentColor" viewBox="0 0 24 24"><path d="M23.5 6.2c-.3-1.1-1.2-2-2.3-2.3C19.3 3.5 12 3.5 12 3.5s-7.3 0-9.2.4c-1.1.3-2 1.2-2.3 2.3C.1 8.1 0 12 0 12s.1 3.9.4 5.8c.3 1.1 1.2 2 2.3 2.3 1.9.4 9.2.4 9.2.4s7.3 0 9.2-.4c1.1-.3 2-1.2 2.3-2.3.4-1.9.5-5.8.5-5.8s-.1-3.9-.4-5.8zM9.75 15.5V8.5l6 3.5-6 3.5z"/></svg>
                  <div>
                    <div class="font-medium">YouTube</div>
                    <div class="text-xs text-zinc-400">国际版</div>
                  </div>
                </a>
              )}
              {data.platforms?.douyin && (
                <a href={data.platforms.douyin} target="_blank" class="flex items-center gap-4 p-5 bg-zinc-900 hover:bg-zinc-800 rounded-2xl transition-all">
                  <!-- TikTok / 抖音 logo -->
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10" fill="currentColor" viewBox="0 0 24 24"><path d="M12.525 2.5v7.3c1.8-.8 3.8-1.2 5.9-1.2v4.8c-2.1 0-4.1.4-5.9 1.2v7.3H6.525v-15h6z"/></svg>
                  <div>
                    <div class="font-medium">抖音</div>
                  </div>
                </a>
              )}
              {data.platforms?.xiaohongshu && (
                <a href={data.platforms.xiaohongshu} target="_blank" class="flex items-center gap-4 p-5 bg-zinc-900 hover:bg-zinc-800 rounded-2xl transition-all">
                  <!-- 小红书 -->
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10 text-[#FF2442]" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2z"/></svg>
                  <div>
                    <div class="font-medium">小红书</div>
                  </div>
                </a>
              )}
              {data.platforms?.local && (
                <a href={data.platforms.local} target="_blank" class="flex items-center gap-4 p-5 bg-zinc-900 hover:bg-zinc-800 rounded-2xl transition-all">
                  <!-- 本地/其他 copyright-bold -->
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10" fill="none" viewBox="0 0 256 256" stroke="currentColor" stroke-width="24"><circle cx="128" cy="128" r="96"/><path d="M128 80a48 48 0 1 0 0 96 48 48 0 0 0 0-96Z"/></svg>
                  <div>
                    <div class="font-medium">本地视频</div>
                  </div>
                </a>
              )}
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>

  <!-- 修复后的倒计时脚本 -->
  <script>
    const countdownEl = document.getElementById('countdown');
    if (countdownEl) {
      const endTime = parseInt(countdownEl.dataset.publishDate);
      const timer = setInterval(() => {
        const diff = endTime - Date.now();
        if (diff < 0) {
          clearInterval(timer);
          window.location.reload();
          return;
        }
        const hours = Math.floor(diff / 3600000).toString().padStart(2, '0');
        const minutes = Math.floor((diff % 3600000) / 60000).toString().padStart(2, '0');
        const seconds = Math.floor((diff % 60000) / 1000).toString().padStart(2, '0');
        countdownEl.textContent = `${hours} : ${minutes} : ${seconds}`;
      }, 1000);
    }
  </script>
</Layout>
